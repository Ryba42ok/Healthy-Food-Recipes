        <prepTime>15 мин + 35 мин</prepTime>
        <servings>4</servings>
        <calories>220 ккал</calories>
        <difficulty>Легко</difficulty>
    </stats>

    <nutrition>
        <protein>6</protein>
        <carbs>28</carbs>
        <fat>12</fat>
        <fiber>5</fiber>
    </nutrition>

    <ingredients>
        <item>600г тыквы</item>
        <item>1 луковица</item>
        <item>2 зубчика чеснока</item>
        <item>2 см корня имбиря</item>

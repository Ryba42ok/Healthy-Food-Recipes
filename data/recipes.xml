        <step>Добавьте зажарку в бульон</step>
        <step>Добавьте рис, варите 15 минут</step>
        <step>Измельчите орехи с чесноком и специями</step>
        <step>Добавьте ореховую массу в суп</step>
        <step>Варите еще 5 минут, добавьте кинзу</step>
    </instructions>
</recipe>

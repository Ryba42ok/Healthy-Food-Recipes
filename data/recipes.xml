    <recipe id="12">
    <title>Суп харчо</title>
    <category>Обеды</category>
    <description>Грузинский суп с говядиной, рисом и грецкими орехами</description>
    <image>harch.png</image>
    
    <stats>
        <prepTime>20 мин + 1 час 20 мин</prepTime>
        <servings>6</servings>
        <calories>320 ккал</calories>
        <difficulty>Средне</difficulty>
    </stats>

    <nutrition>
        <protein>28</protein>
        <carbs>24</carbs>
        <fat>16</fat>
        <fiber>3</fiber>
    </nutrition>

    <ingredients>
        <item>500г говядины</item>
        <item>100г риса</item>
        <item>3 луковицы</item>
        <item>3 зубчика чеснока</item>
        <item>100г грецких орехов</item>
        <item>2 ст.л. томатной пасты</item>
        <item>Хмели-сунели, кориандр</item>
        <item>Ткемали или томатный соус</item>
        <item>Кинза</item>
        <item>Соль, перец</item>
    </ingredients>

    <instructions>
